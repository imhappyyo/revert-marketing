# Revert marketing — copy this to `.env` and fill in. `.env` is git-ignored.
# The system works with NONE of these set (it generates copy + renders images + queues).
# Add keys to unlock each tier. See SETUP.md for the step-by-step.

# ── Tier 2 (optional): fresh AI-written copy each run ─────────────────────────
# Leave blank to use the brand library (perfectly good). Or point at any
# OpenAI-compatible endpoint (your api.gorevert.com proxy, OpenAI, or Gemini).
REVERT_LLM_BASE=https://generativelanguage.googleapis.com/v1beta/openai
REVERT_LLM_HEADER=Authorization: Bearer
REVERT_LLM_KEY=
REVERT_LLM_MODEL=gemini-2.5-flash

# ── Tier 2b (optional): Kling AI video generation for TikTok/Reels ───────────
# app.klingai.com/dev/api-key -> "+ Create a new API Key" (single key, bearer auth).
KLING_API_KEY=
KLING_API_BASE=https://api.klingai.com

# ── Tier 3: fully autonomous posting to ALL channels ─────────────────────────
# Provider: "upload_post" (recommended — file upload, free to start, ~$16/mo) or
#           "ayrshare" (most mature, $149/mo, needs a public media URL).
REVERT_POST_PROVIDER=upload_post

# upload-post.com: create account -> create a profile -> connect socials -> copy key.
UPLOAD_POST_KEY=
UPLOAD_POST_USER=                # the profile name you created in Upload-Post

# ayrshare.com (alternative):
AYRSHARE_KEY=
# AYRSHARE_PROFILE_KEY=          # Business/Enterprise only
REVERT_MEDIA_BASE=              # public URL serving the outbox (Cloudflare R2) — ayrshare only

# Master switch. 1 = publish for real. 0 = dry-run -> QUEUE.md only.
REVERT_POST_LIVE=0
